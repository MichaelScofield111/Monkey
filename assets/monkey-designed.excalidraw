      "link": null,
      "locked": false,
      "text": "#[derive(Debug, Clone)]\npub enum Object {\n    Integer(Integer),\n    Boolean(Boolean),\n    Null(Null),\n    ReturnValue(ReturnValue),\n    Function(Function),\n    MonString(MonString),\n    Builtin(Builtin),\n}\n\n#[derive(Debug, Clone)]\npub struct Integer {\n    pub value: i64,\n}\n\n\n#[derive(Debug, Clone)]\npub struct Function {\n    pub params: Vec<Identifier>,\n    pub body: BlockStatement,\n    pub env: Environment,\n}",
      "fontSize": 28,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "#[derive(Debug, Clone)]\npub enum Object {\n    Integer(Integer),\n    Boolean(Boolean),\n    Null(Null),\n    ReturnValue(ReturnValue),\n    Function(Function),\n    MonString(MonString),\n    Builtin(Builtin),\n}\n\n#[derive(Debug, Clone)]\npub struct Integer {\n    pub value: i64,\n}\n\n\n#[derive(Debug, Clone)]\npub struct Function {\n    pub params: Vec<Identifier>,\n    pub body: BlockStatement,\n    pub env: Environment,\n}",
      "autoResize": true,
      "lineHeight": 1.25
    },
