      "text": "pub struct Lexer<'a> {\n    input: &'a [u8],\n    position: usize, // current char\n\n    // TODO: unicode and utf-8 support\n    ch: u8, // the char being read (at position)\n\n    read_position: usize, // the char after current char\n}",
